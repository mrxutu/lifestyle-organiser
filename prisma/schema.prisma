// schema.prisma
// Lifestyle Organiser — Postgres schema (Prisma 7)
// Run: npx prisma migrate dev --name merge-reminders-into-events

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- USERS & HOUSEHOLDS ----------

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  passwordHash String?
  household    Household? @relation(fields: [householdId], references: [id])
  householdId  String?
  createdAt    DateTime   @default(now())

  eventsCreated Event[]         @relation("EventCreator")
  eventInvites  EventAttendee[]
  recipes       Recipe[]
}

model Household {
  id      String   @id @default(cuid())
  name    String
  users   User[]
  events  Event[]
  recipes Recipe[]
}

// ---------- EVENTS (colour-coded calendar — reminders are events too) ----------

model Event {
  id          String          @id @default(cuid())
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean         @default(false)
  location    String?
  eventType   EventType       @relation(fields: [eventTypeId], references: [id])
  eventTypeId String
  household   Household       @relation(fields: [householdId], references: [id])
  householdId String
  creator     User            @relation("EventCreator", fields: [creatorId], references: [id])
  creatorId   String
  attendees   EventAttendee[]

  // Reminder-style fields — set these to make an event behave as a reminder
  // (e.g. "Car Insurance Renewal"): recurring, with a lead-time "due soon" window.
  // leadTimeDays stays nullable at the DB level (no @default here) — the event
  // FORM should default the input to 0 (opt-out design: new events show on the
  // Reminders page unless this is manually cleared to null, e.g. for "Weekend Away").
  recurrence          Recurrence @default(NONE)
  leadTimeDays        Int? // null = excluded from Reminders page; 0+ = included, due-soon window in days
  remindMinutesBefore Int? // for same-day nudges on regular events, if ever needed

  createdAt DateTime @default(now())
}

enum Recurrence {
  NONE
  MONTHLY
  QUARTERLY
  YEARLY
}

model EventType {
  id     String  @id @default(cuid())
  name   String // e.g. "Weekend Away", "Appointment", "Insurance", "Bill"
  color  String // hex code — drives calendar colour-coding
  events Event[]
}

model EventAttendee {
  id      String @id @default(cuid())
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String
  user    User   @relation(fields: [userId], references: [id])
  userId  String

  @@unique([eventId, userId])
}

// ---------- RECIPES ----------

model Recipe {
  id          String       @id @default(cuid())
  title       String
  description String?
  imageUrl    String?
  servings    Int?
  prepMinutes Int?
  cookMinutes Int?
  tags        String[]
  ingredients Ingredient[]
  method      String? // single multi-line text field, pasted in — not a repeatable Step model
  household   Household    @relation(fields: [householdId], references: [id])
  householdId String
  author      User         @relation(fields: [authorId], references: [id])
  authorId    String
  createdAt   DateTime     @default(now())
}

model Ingredient {
  id       String           @id @default(cuid())
  recipe   Recipe           @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String
  name     String // e.g. "Sugar", "Lemon", "Milk"
  amount   Float? // supports decimals, e.g. 1.5 — null if the ingredient has no quantity (rare)
  unit     MeasurementUnit? // null = no unit, e.g. "1 lemon" rather than "1 whole lemon"
  order    Int              @default(0)
}

enum MeasurementUnit {
  TSP
  TBSP
  G
  ML
  LITRE
  PINT
  OZ
  LB
}
